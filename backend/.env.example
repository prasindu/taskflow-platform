
# Database Configuration
# Replace 'username', 'password', and 'db_name' with your PostgreSQL credentials
DATABASE_URL="postgresql://username:password@localhost:5432/db_name"

# Authentication
# Replace with a strong random string in production
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# Email Service (Resend)
# Add your Resend API Key here
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM="CyphLab <onboarding@resend.dev>"

# Application Settings
FRONTEND_URL="http://localhost:3000"
PORT=5000

# Initial Admin Setup Credentials (For Seeding)
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="Admin11223"
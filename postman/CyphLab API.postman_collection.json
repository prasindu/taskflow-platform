  "info": {
    "_postman_id": "742bc381-14f5-4a92-82b6-940456e56557",
    "name": "CyphLab API",
    "description": "StartFragment\n\nThis collection contains all the RESTful API endpoints for the CyphLab platform.\n\n**Key Features Included:**\n\n- **Authentication & RBAC:** Secure login and role-based access control (Admin, PM, Member).\n    \n- **Project Management:** Endpoints to create, update, and manage project details and members.\n    \n- **Task Management:** Complete Kanban-style task workflows with status tracking.\n    \n- **Team Chat:** Real-time project-specific messaging.\n    \n- **Analytics & Audit Logs:** Role-based dashboard stats and system-wide activity tracking.\n    \n\n_Note: Please ensure to log in and set the Bearer Token in the Authorization tab for protected routes._\n\nEndFragment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "41760967"
  },
